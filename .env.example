# ── Telegram ──────────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# ── Chat models (at least one required) ───────────────────────────────────────
# Groq  → https://console.groq.com          (free, no card needed)
# Gemini → https://aistudio.google.com      (free, no card needed)
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ── Database ──────────────────────────────────────────────────────────────────
# Railway provides this automatically when you add a Postgres addon.
# For other providers (Neon, Supabase): copy the connection string from their dashboard.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Vector store ──────────────────────────────────────────────────────────────
# Qdrant Cloud → https://cloud.qdrant.io    (free 1 GB tier, no card needed)
# Copy cluster URL and API key from the Qdrant Cloud console.
QDRANT_URL=https://your-cluster-id.us-east4-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate once and never change (changing it makes stored passwords unreadable):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_generated_fernet_key_here
